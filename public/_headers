# Long-cache immutable, content-hashed variants of the hero LCP image.
# Safe because the filenames are versioned (dimensions in the name); if we
# regenerate at a different size or quality we ship a new filename.
/hero-lcp-*.avif
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept

/hero-lcp-*.webp
  Cache-Control: public, max-age=31536000, immutable
  Vary: Accept

/hero-lcp.webp
  Cache-Control: public, max-age=31536000, immutable

/spring-promotion-poster.webp
  Cache-Control: public, max-age=31536000, immutable

# Hashed JS/CSS emitted by Vite
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML entry points must revalidate so new deploys are picked up.
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
